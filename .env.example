REMORPH_APP_NAME=ReMorph
REMORPH_APP_ENV=development
REMORPH_DEBUG=true

REMORPH_GROQ_API_KEY=API_KEY
REMORPH_LLM_MODEL=groq/openai/gpt-oss-20b

REMORPH_REQUEST_TIMEOUT_SECONDS=10
REMORPH_MAX_FETCH_RETRIES=2
REMORPH_LOG_LEVEL=INFO

REMORPH_ENABLE_AUTH_HEALING=true
REMORPH_ENABLE_ROUTE_HEALING=true
REMORPH_ENABLE_PAYLOAD_HEALING=true

REMORPH_LOCAL_SPEC_PATH=app/testsupport/sample_openapi.json

# Sprint 4 runtime settings
REMORPH_S4_ENV_BACKEND=simulated
REMORPH_S4_OPENENV_CLIENT_MODULE=echo_env
REMORPH_S4_OPENENV_CLIENT_CLASS=EchoEnv
REMORPH_S4_OPENENV_BASE_URL=
REMORPH_S4_OPENENV_STRICT=false
REMORPH_S4_EPISODE_LOG_PATH=runtime/sprint4/episodes.jsonl
REMORPH_S4_BENCHMARK_OUTPUT_DIR=runtime/sprint4
REMORPH_S4_MAX_REPAIR_CYCLES=2
