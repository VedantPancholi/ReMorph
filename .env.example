REMORPH_APP_NAME=ReMorph
REMORPH_APP_ENV=development
REMORPH_DEBUG=true

REMORPH_GROQ_API_KEY=
REMORPH_LLM_MODEL=groq/llama-3.1-8b-instant

REMORPH_REQUEST_TIMEOUT_SECONDS=10
REMORPH_MAX_FETCH_RETRIES=2
REMORPH_LOG_LEVEL=INFO

REMORPH_ENABLE_AUTH_HEALING=true
REMORPH_ENABLE_ROUTE_HEALING=true
REMORPH_ENABLE_PAYLOAD_HEALING=true

REMORPH_LOCAL_SPEC_PATH=app/testsupport/sample_openapi.json
